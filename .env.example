HOST=127.0.0.1
PORT=7077
OPENAI_API_KEY=sk-...
TRANSCRIPTION_MODEL=gpt-4o-transcribe
SPEECH_TO_TEXT_API_KEYS=replace-with-client-token
CLIENT_KEYS_FILE=/etc/speech-to-text/client-keys.json
ADMIN_API_TOKEN=replace-with-admin-token
